<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
   <div  class="col-8 offset-2">
    <h2>Listing Details:</h2>
<div class="card col-6 offset-2 show-card" >
  <img src="<%= listing.img ? listing.img : (listing.image && listing.image.url ? listing.image.url : '/css/placeholder.png') %>"  class="card-img-top show-img" alt="Listing_img">
  <div class="card-body">
    <p class="card-text">
        <b><%= listing.title %></b></p>
        <%= listing.description %> <br>
        &#8377;<%= listing.price %> <br>
        <%= listing.location %> <br>
        <%= listing.country %> <br>
  </div>
</div>
<div class="btns">
<a href="/listing/<%= listing._id %>/edit" class="btn btn-danger col-1 offset-2 edit-btn">Edit</a>
<form method="POST" action="/listing/<%= listing._id %>?_method=DELETE">
    <button class="btn btn-dark offset-2">Delete</button>
</form>
</div>
 </div>

</div>
