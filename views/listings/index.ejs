<% layout("/layouts/boilerplate") %>
    <h3>All Listings</h3>

<% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
    <p><%= allListings.length %> result(s) found for "<b><%= searchQuery %></b>"</p>
<% } %>

<% if (allListings.length === 0) { %>
    <div class="text-center mt-4">
        <h5>No listings found for "<%= searchQuery %>"</h5>
        <a href="/listings" class="btn btn-outline-danger mt-2">View all listings</a>
    </div>
<!-- <% } else { %>
  <% if (typeof nearby !== 'undefined' && nearby) { %>
    <p><i class="fa-solid fa-location-dot"></i> Showing <b><%= allListings.length %></b> listings within 50km of your location</p> -->
<% } %>
    <div class="row row-cols-lg-3 row-cols-lg-2 row-cols-lg-1">
        <% for(let listing of allListings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-links">
                <div class="card col listing-card">
                    <img src="<%= listing.img ? listing.img : (listing.image && listing.image.url ? listing.image.url : '/css/placeholder.png') %>" 
                         class="card-img-top" 
                         alt="listing_img" 
                         style="height: 18rem">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b><br>
                            &#8377;<%= listing.price %>/night
                        </p>
                    </div>
                </div>
            </a>
        <% } %>
    </div>
<% } %>