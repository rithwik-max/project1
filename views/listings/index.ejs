<% layout("/layouts/boilerplate") %><% success  %>
    <h3>All Listings</h3>
    <!-- <form action="/listings/new" method="GET" >
        <button>New Post</button>
    </form> -->
<div class=" row row-cols-lg-3 row-cols-lg-2 row-cols-lg-1">
        <% for(let listing of allListings) { %>
              <a href="/listings/<%= listing._id %>" class="listing-links">
        <div class="card col listing-card " >
  <img src="<%= listing.img ? listing.img : (listing.image && listing.image.url ? listing.image.url : '/css/placeholder.png') %>" class="card-img-top" alt="listing_img" style="height: 18rem">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text"><b><%= listing.title %></b><br>
    &#8377;<%= listing.price %>/night</p>
  </div>
</div>
</a>
<% } %>
</div>
</body>   