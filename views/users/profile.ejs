<% layout("/layouts/boilerplate") %>

<div class="container mt-4">
    <div class="row">

        <!-- LEFT: Profile Card -->
        <div class="col-md-4 text-center">
            <div class="card p-4 shadow-sm">
                <img src="<%= user.profileImage.url %>" 
                     class="rounded-circle mx-auto d-block mb-3" 
                     style="width: 120px; height: 120px; object-fit: cover;">
                <h4><%= user.username %></h4>
                <p class="text-muted"><%= user.email %></p>
                <% if(user.phone) { %>
                    <p><i class="fa-solid fa-phone"></i> <%= user.phone %></p>
                <% } %>
                <% if(user.bio) { %>
                    <p><%= user.bio %></p>
                <% } %>
                <p class="text-muted small">
                    Joined <%= user.joinedAt.toDateString() %>
                </p>
                <a href="/profile/edit" class="btn btn-outline-danger w-100">
                    <i class="fa-solid fa-pen"></i> Edit Profile
                </a>
            </div>
        </div>

        <!-- RIGHT: My Listings -->
        <div class="col-md-8">
            <h4>My Listings <span class="badge bg-danger"><%= myListings.length %></span></h4>
            <hr>
            <% if(myListings.length === 0) { %>
                <p class="text-muted">You haven't added any listings yet.</p>
                <a href="/listings/new" class="btn btn-outline-danger">
                    + Add your first listing
                </a>
            <% } else { %>
                <div class="row row-cols-2 g-3">
                    <% for(let listing of myListings) { %>
                        <div class="col">
                            <a href="/listings/<%= listing._id %>" class="listing-links">
                                <div class="card listing-card">
                                    <img src="<%= listing.image && listing.image.url ? listing.image.url : '/css/placeholder.png' %>" 
                                         class="card-img-top" style="height: 150px; object-fit: cover;">
                                    <div class="card-body p-2">
                                        <p class="card-text mb-1"><b><%= listing.title %></b></p>
                                        <p class="card-text text-muted small">₹<%= listing.price %>/night</p>
                                    </div>
                                </div>
                            </a>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>

    </div>
</div>